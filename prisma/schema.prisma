generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BotConfig {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model MarketSnapshot {
  id        String   @id @default(cuid())
  symbol    String
  timeframe String
  price     Float
  rsi       Float?
  barsJson  String
  createdAt DateTime @default(now())

  @@index([symbol, createdAt])
}

model Signal {
  id                  String   @id @default(cuid())
  symbol              String
  action              String
  confidence          Float
  rsi                 Float?
  reason              String
  recommendedNotional Float?
  createdAt           DateTime @default(now())

  @@index([symbol, createdAt])
}

model AiAudit {
  id                         String   @id @default(cuid())
  symbol                     String
  promptHash                 String
  inputJson                  String
  outputJson                 String
  decision                   String
  confidence                 Float
  rationale                  String
  riskFlagsJson              String
  learningUpdateJson         String
  recommendedAdjustmentsJson String
  accepted                   Boolean
  rejectionReasonsJson       String
  tradeOutcomeJson           String?
  openAiResponseId           String?
  createdAt                  DateTime @default(now())

  @@index([symbol, createdAt])
  @@index([createdAt])
}

model Trade {
  id               String    @id @default(cuid())
  symbol           String
  side             String
  strategy         String    @default("rsi_ai")
  qty              Float?
  notional         Float?
  price            Float?
  orderId          String?
  status           String
  realizedPnl      Float?
  rationale        String?
  tradeOutcomeJson String?
  filledAt         DateTime?
  reconciledAt     DateTime?
  createdAt        DateTime  @default(now())
  closedAt         DateTime?

  @@index([symbol, createdAt])
  @@index([strategy, createdAt])
  @@index([orderId])
  @@index([status, createdAt])
}

model LearningEvent {
  id        String   @id @default(cuid())
  symbol    String
  reward    Float
  summary   String
  source    String
  createdAt DateTime @default(now())

  @@index([symbol, createdAt])
}

model ResearchItem {
  id             String   @id @default(cuid())
  externalId     String   @unique
  symbol         String
  source         String
  sourceUrl      String
  headline       String
  summary        String?
  contentHash    String
  allSymbolsJson String
  sentiment      String
  catalyst       String?
  riskFlagsJson  String
  confidence     Float
  publishedAt    DateTime
  discoveredAt   DateTime @default(now())
  expiresAt      DateTime

  @@index([symbol, publishedAt])
  @@index([expiresAt])
}

model Opportunity {
  id                String   @id @default(cuid())
  symbol            String
  direction         String
  thesis            String
  catalyst          String
  confidence        Float
  score             Float
  sourceItemIdsJson String
  riskFlagsJson     String
  status            String   @default("active")
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now()) @updatedAt
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  @@index([symbol, status, expiresAt])
  @@index([score])
  @@index([expiresAt])
}

model TradePlan {
  id               String          @id @default(cuid())
  status           String          @default("active")
  inputSummaryJson String
  generatedAt      DateTime        @default(now())
  createdAt        DateTime        @default(now())
  items            TradePlanItem[]

  @@index([status, generatedAt])
  @@index([generatedAt])
}

model TradePlanItem {
  id                 String    @id @default(cuid())
  planId             String
  plan               TradePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  rank               Int
  symbol             String
  suggestedAction    String
  thesis             String
  catalyst           String
  confidence         Float
  score              Float
  riskNotesJson      String
  eligibleForRsi     Boolean
  tradableNow        Boolean
  tradabilityReason  String
  opportunityIdsJson String
  sourceUrlsJson     String
  learningNotesJson  String
  positionJson       String?
  createdAt          DateTime  @default(now())

  @@index([planId, rank])
  @@index([symbol, createdAt])
}
