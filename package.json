{
  "name": "ai-rsi-trading-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "prisma generate && next build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "node scripts/db-push.mjs",
    "db:prisma-push": "prisma db push",
    "bot:scan": "node --import tsx scripts/run-scan.ts",
    "bot:worker": "node --import tsx scripts/worker.ts",
    "bot:reconcile": "node --import tsx scripts/reconcile-trades.ts",
    "research:crawl": "node --import tsx scripts/research-crawl.ts",
    "health:alpaca": "node --import tsx scripts/alpaca-health.ts"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "@prisma/client": "^5.22.0",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "openai": "^6.45.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "technicalindicators": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "prisma": "^5.22.0",
    "railway": "^3.4.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "axios": "1.18.1",
    "postcss": "8.5.16"
  }
}
